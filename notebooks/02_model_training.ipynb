    "                xticklabels=['No CHD', 'CHD'], yticklabels=['No CHD', 'CHD'])\n",
    "    axes[i].set_title(f'{name}')\n",
    "    axes[i].set_ylabel('Actual')\n",
    "    axes[i].set_xlabel('Predicted')\n",
