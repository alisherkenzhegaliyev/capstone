   "source": [
    "optimal_thresholds = {}\n",
    "\n",
    "for name in models:\n",
    "    y_proba = predictions[name]['y_proba']\n",
    "    precisions, recalls, thresholds = precision_recall_curve(y_test, y_proba)\n",
    "    f1_scores = 2 * (precisions[:-1] * recalls[:-1]) / (precisions[:-1] + recalls[:-1] + 1e-8)\n",
    "    best_idx = np.argmax(f1_scores)\n",
    "    best_threshold = thresholds[best_idx]\n",
    "    optimal_thresholds[name] = best_threshold\n",
    "\n",
    "    y_pred_opt = (y_proba >= best_threshold).astype(int)\n",
    "\n",
    "    print(f\"{name}:\")\n",
    "    print(f\"  Optimal threshold: {best_threshold:.3f}\")\n",
    "    print(f\"  F1 (default 0.5):  {f1_score(y_test, predictions[name]['y_pred']):.4f}\")\n",
    "    print(f\"  F1 (optimized):    {f1_score(y_test, y_pred_opt):.4f}\")\n",
    "    print(f\"  Recall CHD (0.5):  {(predictions[name]['y_pred'][y_test == 1].sum() / (y_test == 1).sum()):.4f}\")\n",
    "    print(f\"  Recall CHD (opt):  {(y_pred_opt[y_test == 1].sum() / (y_test == 1).sum()):.4f}\")\n",
    "    print()"
   ]
