   "source": [
    "from sklearn.metrics import recall_score\n",
    "# ROC curves вЂ” all 5 models\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n",
    "\n",
    "colors = ['steelblue', 'darkorange', 'green', 'red', 'purple']\n",
    "for (name, _), color in zip(all_models.items(), colors):\n",
    "    y_proba = all_predictions[name]['y_proba']\n",
    "    fpr, tpr, _ = roc_curve(y_test, y_proba)\n",
    "    roc_auc = roc_auc_score(y_test, y_proba)\n",
    "    axes[0].plot(fpr, tpr, linewidth=2, label=f'{name} (AUC={roc_auc:.3f})', color=color)\n",
    "\n",
    "axes[0].plot([0, 1], [0, 1], 'k--', label='Random')\n",
    "axes[0].set_xlabel('False Positive Rate')\n",
    "axes[0].set_ylabel('True Positive Rate')\n",
    "axes[0].set_title('ROC Curves вЂ” All Models')\n",
    "axes[0].legend(fontsize=9)\n",
    "\n",
    "for (name, _), color in zip(all_models.items(), colors):\n",
    "    y_proba = all_predictions[name]['y_proba']\n",
    "    precision, recall, _ = precision_recall_curve(y_test, y_proba)\n",
    "    pr_auc = average_precision_score(y_test, y_proba)\n",
    "    axes[1].plot(recall, precision, linewidth=2, label=f'{name} (AP={pr_auc:.3f})', color=color)\n",
    "\n",
    "axes[1].set_xlabel('Recall')\n",
    "axes[1].set_ylabel('Precision')\n",
    "axes[1].set_title('Precision-Recall Curves вЂ” All Models')\n",
    "axes[1].legend(fontsize=9)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Threshold optimization for all 5 models\n",
    "print(\"Threshold Optimization:\\n\")\n",
    "all_thresholds = {}\n",
    "for name in all_models:\n",
    "    y_proba = all_predictions[name]['y_proba']\n",
    "    precisions, recalls, thresholds = precision_recall_curve(y_test, y_proba)\n",
    "    f1_scores = 2 * (precisions[:-1] * recalls[:-1]) / (precisions[:-1] + recalls[:-1] + 1e-8)\n",
    "    best_idx = np.argmax(f1_scores)\n",
    "    best_threshold = thresholds[best_idx]\n",
    "    all_thresholds[name] = best_threshold\n",
    "    y_pred_opt = (y_proba >= best_threshold).astype(int)\n",
    "    print(f\"{name}: threshold={best_threshold:.3f}  F1(0.5)={f1_score(y_test, all_predictions[name]['y_pred']):.4f}  F1(opt)={f1_score(y_test, y_pred_opt):.4f}  CHD-recall(opt)={recall_score(y_test, y_pred_opt):.4f}\")\n",
    "\n",
    "fig, axes = plt.subplots(1, 5, figsize=(22, 4))\n",
    "for i, (name, model) in enumerate(all_models.items()):\n",
    "    y_proba = all_predictions[name]['y_proba']\n",
    "    y_pred_opt = (y_proba >= all_thresholds[name]).astype(int)\n",
    "    cm = confusion_matrix(y_test, y_pred_opt)\n",
    "    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[i],\n",
    "                xticklabels=['No CHD', 'CHD'], yticklabels=['No CHD', 'CHD'])\n",
    "    axes[i].set_title(f'{name}\\n(thr={all_thresholds[name]:.3f})', fontsize=9)\n",
    "    axes[i].set_ylabel('Actual')\n",
    "    axes[i].set_xlabel('Predicted')\n",
    "\n",
    "plt.suptitle('Confusion Matrices вЂ” Optimized Thresholds (All Models)', fontsize=12)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
