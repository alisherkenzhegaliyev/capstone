   "source": [
    "# Confusion matrices\n",
    "fig, axes = plt.subplots(1, 3, figsize=(16, 4))\n",
    "\n",
    "for i, (name, model) in enumerate(models.items()):\n",
    "    cm = confusion_matrix(y_test, predictions[name]['y_pred'])\n",
