 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 2: Model Training & Comparison\n",
    "## XGBoost, Random Forest, Logistic Regression"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-07T09:01:35.825329Z",
     "iopub.status.busy": "2026-03-07T09:01:35.824330Z",
     "iopub.status.idle": "2026-03-07T09:01:38.450209Z",
     "shell.execute_reply": "2026-03-07T09:01:38.448858Z"
    }
   },
   "outputs": [],
   "source": [
    "import os\n",
    "import json\n",
    "import pickle\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.model_selection import RandomizedSearchCV, GridSearchCV, StratifiedKFold\n",
    "from sklearn.metrics import (\n",
    "    accuracy_score, f1_score, roc_auc_score, roc_curve,\n",
    "    confusion_matrix, classification_report, precision_recall_curve,\n",
    "    average_precision_score\n",
    ")\n",
    "from imblearn.pipeline import Pipeline as ImbPipeline\n",
    "from imblearn.over_sampling import SMOTE\n",
    "import xgboost as xgb\n",
    "\n",
    "RANDOM_STATE = 42\n",
    "np.random.seed(RANDOM_STATE)\n",
    "\n",
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=RANDOM_STATE)\n",
    "\n",
    "sns.set_style('whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (10, 6)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Preprocessed Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-07T09:01:38.453224Z",
     "iopub.status.busy": "2026-03-07T09:01:38.453224Z",
     "iopub.status.idle": "2026-03-07T09:01:38.463229Z",
     "shell.execute_reply": "2026-03-07T09:01:38.462211Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Original training set: (3392, 13) (class dist: {0: 2877, 1: 515})\n",
      "SMOTE training set:    (5178, 13) (class dist: {0: 2877, 1: 2301})\n",
      "Test set:              (848, 13)\n",
      "Features (13): ['age', 'sex', 'total_cholesterol', 'systolic_bp', 'smoking', 'diabetes', 'bmi', 'heart_rate', 'glucose', 'bp_meds', 'prevalent_hypertension', 'cigs_per_day', 'pulse_pressure']\n"
     ]
    }
   ],
   "source": [
    "with open('../models/processed_data.pkl', 'rb') as f:\n",
    "    data = pickle.load(f)\n",
    "\n",
    "X_train = data['X_train_processed']\n",
    "y_train = data['y_train']\n",
    "\n",
    "X_train_resampled = data['X_train_resampled']\n",
    "y_train_resampled = data['y_train_resampled']\n",
    "\n",
    "X_test_processed = data['X_test_processed']\n",
    "y_test = data['y_test']\n",
    "feature_cols = data['feature_cols']\n",
    "\n",
    "print(f\"Original training set: {X_train.shape} (class dist: {pd.Series(y_train).value_counts().to_dict()})\")\n",
    "print(f\"SMOTE training set:    {X_train_resampled.shape} (class dist: {pd.Series(y_train_resampled).value_counts().to_dict()})\")\n",
    "print(f\"Test set:              {X_test_processed.shape}\")\n",
    "print(f\"Features ({len(feature_cols)}): {feature_cols}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Train Models with Hyperparameter Tuning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-07T09:01:38.495231Z",
     "iopub.status.busy": "2026-03-07T09:01:38.494232Z",
     "iopub.status.idle": "2026-03-07T09:02:02.272037Z",
     "shell.execute_reply": "2026-03-07T09:02:02.270515Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Fitting 5 folds for each of 80 candidates, totalling 400 fits\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Best XGBoost CV ROC-AUC: 0.7143\n",
      "Best params: {'subsample': 0.7, 'reg_lambda': 1.5, 'reg_alpha': 0.01, 'n_estimators': 500, 'min_child_weight': 7, 'max_depth': 3, 'learning_rate': 0.01, 'gamma': 0.1, 'colsample_bytree': 0.7}\n"
     ]
    }
   ],
   "source": [
    "xgb_pipe = ImbPipeline([\n",
    "    ('smote', SMOTE(random_state=RANDOM_STATE, sampling_strategy=0.8)),\n",
    "    ('clf', xgb.XGBClassifier(\n",
    "        objective='binary:logistic',\n",
    "        eval_metric='aucpr',\n",
    "        random_state=RANDOM_STATE,\n",
    "    ))\n",
    "])\n",
    "\n",
    "xgb_param_dist = {\n",
    "    'clf__max_depth': [3, 4, 5, 6, 7, 8],\n",
    "    'clf__learning_rate': [0.01, 0.03, 0.05, 0.1, 0.15, 0.2],\n",
    "    'clf__n_estimators': [100, 200, 300, 400, 500],\n",
    "    'clf__subsample': [0.6, 0.7, 0.8, 0.9, 1.0],\n",
    "    'clf__colsample_bytree': [0.5, 0.6, 0.7, 0.8, 0.9, 1.0],\n",
    "    'clf__min_child_weight': [1, 3, 5, 7, 10],\n",
    "    'clf__gamma': [0, 0.1, 0.2, 0.3, 0.5],\n",
    "    'clf__reg_alpha': [0, 0.01, 0.1, 0.5, 1.0],\n",
    "    'clf__reg_lambda': [0.5, 1.0, 1.5, 2.0, 3.0],\n",
    "}\n",
    "\n",
    "xgb_search = RandomizedSearchCV(\n",
    "    xgb_pipe, xgb_param_dist,\n",
    "    n_iter=80, cv=cv, scoring='roc_auc',\n",
    "    random_state=RANDOM_STATE, n_jobs=-1, verbose=1\n",
    ")\n",
    "xgb_search.fit(X_train, y_train)\n",
    "\n",
    "# Extract the trained classifier for deployment\n",
    "model_xgb = xgb_search.best_estimator_.named_steps['clf']\n",
    "\n",
    "print(f\"\\nBest XGBoost CV ROC-AUC: {xgb_search.best_score_:.4f}\")\n",
    "best_xgb_params = {k.replace('clf__', ''): v for k, v in xgb_search.best_params_.items()}\n",
    "print(f\"Best params: {best_xgb_params}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-07T09:02:02.275030Z",
     "iopub.status.busy": "2026-03-07T09:02:02.275030Z",
     "iopub.status.idle": "2026-03-07T09:03:37.687226Z",
     "shell.execute_reply": "2026-03-07T09:03:37.686219Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Fitting 5 folds for each of 60 candidates, totalling 300 fits\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Best RF CV ROC-AUC: 0.7180\n",
      "Best params: {'n_estimators': 400, 'min_samples_split': 10, 'min_samples_leaf': 4, 'max_features': 'log2', 'max_depth': 5, 'class_weight': None}\n"
     ]
    }
   ],
   "source": [
    "# Random Forest with SMOTE in pipeline\n",
    "rf_pipe = ImbPipeline([\n",
    "    ('smote', SMOTE(random_state=RANDOM_STATE, sampling_strategy=0.8)),\n",
    "    ('clf', RandomForestClassifier(random_state=RANDOM_STATE, n_jobs=-1))\n",
    "])\n",
    "\n",
    "rf_param_dist = {\n",
    "    'clf__n_estimators': [200, 300, 400, 500],\n",
    "    'clf__max_depth': [5, 8, 10, 15, 20, None],\n",
    "    'clf__min_samples_split': [2, 5, 10, 15, 20],\n",
    "    'clf__min_samples_leaf': [1, 2, 4, 8],\n",
    "    'clf__max_features': ['sqrt', 'log2', 0.3, 0.5, 0.7],\n",
    "    'clf__class_weight': [None, 'balanced', 'balanced_subsample'],\n",
    "}\n",
    "\n",
    "rf_search = RandomizedSearchCV(\n",
    "    rf_pipe, rf_param_dist,\n",
    "    n_iter=60, cv=cv, scoring='roc_auc',\n",
    "    random_state=RANDOM_STATE, n_jobs=-1, verbose=1\n",
    ")\n",
    "rf_search.fit(X_train, y_train)\n",
    "\n",
    "model_rf = rf_search.best_estimator_.named_steps['clf']\n",
    "\n",
    "print(f\"\\nBest RF CV ROC-AUC: {rf_search.best_score_:.4f}\")\n",
    "best_rf_params = {k.replace('clf__', ''): v for k, v in rf_search.best_params_.items()}\n",
    "print(f\"Best params: {best_rf_params}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-07T09:03:37.689227Z",
     "iopub.status.busy": "2026-03-07T09:03:37.689227Z",
     "iopub.status.idle": "2026-03-07T09:03:40.421311Z",
     "shell.execute_reply": "2026-03-07T09:03:40.420298Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Fitting 5 folds for each of 240 candidates, totalling 1200 fits\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Best LR CV ROC-AUC: 0.7320\n",
      "Best params: {'C': 0.01, 'l1_ratio': 0.0, 'smote_sampling_strategy': 0.6}\n"
     ]
    },
    
   ],
   "source": [
    "# Logistic Regression with SMOTE in pipeline\n",
    "lr_pipe = ImbPipeline([\n",
    "    ('smote', SMOTE(random_state=RANDOM_STATE, sampling_strategy=0.8)),\n",
    "    ('clf', LogisticRegression(max_iter=1000, random_state=RANDOM_STATE, solver='liblinear'))\n",
    "])\n",
    "\n",
    "lr_param_grid = {\n",
    "    'clf__C': [0.001, 0.01, 0.05, 0.1, 0.5, 1.0, 5.0, 10.0],\n",
    "    'clf__l1_ratio': [0.0, 0.25, 0.5, 0.75, 1.0],\n",
    "    'smote__sampling_strategy': [0.5, 0.6, 0.7, 0.8, 0.9, 1.0],\n",
    "}\n",
    "\n",
    "lr_search = GridSearchCV(\n",
    "    lr_pipe, lr_param_grid,\n",
    "    cv=cv, scoring='roc_auc',\n",
    "    n_jobs=-1, verbose=1\n",
    ")\n",
    "lr_search.fit(X_train, y_train)\n",
    "\n",
    "model_lr = lr_search.best_estimator_.named_steps['clf']\n",
    "\n",
    "print(f\"\\nBest LR CV ROC-AUC: {lr_search.best_score_:.4f}\")\n",
    "best_lr_params = {k.replace('clf__', '').replace('smote__', 'smote_'): v \n",
    "                  for k, v in lr_search.best_params_.items()}\n",
    "print(f\"Best params: {best_lr_params}\")"
   ]
  },
  {
